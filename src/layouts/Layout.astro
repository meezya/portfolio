---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const { title = 'Rameez Ahmad', description = 'Iso Design & Research' } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body class="bg-black text-neutral-100 antialiased font-serif">
		<slot />
	</body>
</html>
